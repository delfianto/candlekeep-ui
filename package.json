{
  "name": "candlekeep-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --host",
    "build": "vue-tsc -b && vp build",
    "preview": "vp preview",
    "lint": "vp lint",
    "fmt": "vp fmt .",
    "fmt:check": "vp fmt --check .",
    "typecheck": "vue-tsc --noEmit",
    "api:gen": "openapi-typescript ../candlekeep-core/openapi.json -o ./src/api/schema.d.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/ui": "^4.8.2",
    "@vueuse/core": "^14.3.0",
    "dompurify": "^3.4.9",
    "markdown-it": "^14.2.0",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tsconfig/node18": "^18.2.6",
    "@types/bun": "^1.3.14",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.24",
    "vite-plugin-terminal": "^1.4.0",
    "vue-tsc": "^3.3.4",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "packageManager": "bun@1.3.14",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
