{
  "name": "candlekeep-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "vue-tsc --noEmit",
    "api:gen": "openapi-typescript ../candlekeep-core/openapi.json -o ./src/api/schema.d.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.45",
    "@nuxt/ui": "^3.1.3",
    "@vueuse/core": "^14.1.0",
    "dompurify": "^3.3.1",
    "markdown-it": "^14.1.0",
    "openapi-fetch": "^0.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tsconfig/node18": "^18.2.6",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.10.1",
    "oxlint": "^1.33.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0-beta.3",
    "vite-plugin-terminal": "^1.3.0",
    "vue-tsc": "^3.1.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
